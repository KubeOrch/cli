# Development Dockerfile for Core (with hot reload)
FROM golang:1.21-alpine

# Install air for hot reload
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Expose port (Core runs on 3000)
EXPOSE 3000

# Run with air for hot reload
CMD ["air"]